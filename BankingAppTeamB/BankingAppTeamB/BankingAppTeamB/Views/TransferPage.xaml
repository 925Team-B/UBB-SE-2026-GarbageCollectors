<Page
    x:Class="BankingAppTeamB.Views.TransferPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:BankingAppTeamB.Converters">

    <Page.Resources>
        <converters:StepToVisibilityConverter x:Key="StepToVisibility"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </Page.Resources>

    <ScrollViewer Padding="40">
        <StackPanel MaxWidth="520" HorizontalAlignment="Center" Spacing="24">

            <TextBlock
                Text="Transfer"
                FontSize="28"
                FontWeight="SemiBold"/>

            <InfoBar
                IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                Severity="Error"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>

            <StackPanel
                Spacing="16"
                Visibility="{x:Bind ViewModel.CurrentStep,
                             Mode=OneWay,
                             Converter={StaticResource StepToVisibility},
                             ConverterParameter=1}">

                <TextBlock
                    Text="Step 1 of 4 — Select source account"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <TextBlock Text="Source account" FontSize="13"/>
                <ComboBox
                    ItemsSource="{x:Bind ViewModel.Accounts, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedAccount, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    PlaceholderText="Select an account">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Name}"/>
                                <TextBlock
                                    Text="{Binding Currency}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button
                    Content="Next"
                    Command="{x:Bind ViewModel.NextStepCommand}"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"/>

            </StackPanel>

            <StackPanel
                Spacing="16"
                Visibility="{x:Bind ViewModel.CurrentStep,
                             Mode=OneWay,
                             Converter={StaticResource StepToVisibility},
                             ConverterParameter=2}">

                <TextBlock
                    Text="Step 2 of 4 — Recipient details"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <TextBlock Text="Recipient name" FontSize="13"/>
                <TextBox
                    Text="{x:Bind ViewModel.RecipientName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="e.g. John Smith"/>

                <TextBlock Text="Recipient IBAN" FontSize="13"/>
                <TextBox
                    Text="{x:Bind ViewModel.RecipientIBAN, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="e.g. RO49AAAA1B31007593840000"/>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    Visibility="{x:Bind ViewModel.IsIBANValid, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock
                        Text="Bank:"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontSize="13"/>
                    <TextBlock
                        Text="{x:Bind ViewModel.BankName, Mode=OneWay}"
                        FontSize="13"
                        Foreground="Green"/>
                </StackPanel>

                <TextBlock
                    Text="Invalid IBAN. Please check the format."
                    Foreground="Red"
                    FontSize="13"
                    Visibility="{x:Bind ViewModel.IsIBANValid,
                                 Mode=OneWay,
                                 Converter={StaticResource InverseBoolToVisibility}}"/>

                <Button
                    Content="Next"
                    Command="{x:Bind ViewModel.NextStepCommand}"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"/>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
